# GraphQL Endpoints (runtime - used by the Next.js app)
# Note: Dashboard/CRM endpoint is determined dynamically by database API selection
# or Direct Connect configuration - it's not configured via environment variable
NEXT_PUBLIC_SCHEMA_BUILDER_GRAPHQL_ENDPOINT=http://api.localhost:3000/graphql
NEXT_PUBLIC_AUTH_GRAPHQL_ENDPOINT=http://auth.localhost:3000/graphql
NEXT_PUBLIC_ADMIN_GRAPHQL_ENDPOINT=http://admin.localhost:3000/graphql

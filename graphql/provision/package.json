{
  "name": "@constructive-templates/provision",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "copy": "copyfiles -f ../../LICENSE README.md package.json dist",
    "clean": "rimraf dist/**",
    "build": "pnpm run clean; tsc; tsc -p tsconfig.esm.json; pnpm run copy",
    "provision": "tsx provision.ts",
    "deps": "pnpm up -r -i -L"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/pg": "^8.11.0",
    "copyfiles": "^2",
    "rimraf": "^5",
    "tsx": "^4.22.3",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@constructive-io/fetch": "^1.0.0",
    "@constructive-io/sdk": "^0.23.1",
    "pg": "^8.13.0"
  }
}
